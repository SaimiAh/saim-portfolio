# ========================
# Environment & Secrets
# ========================
.env                  # Environment variables (API keys, secrets — never commit this)

# ========================
# Python Cache & Bytecode
# ========================
__pycache__/          # Python's bytecode cache directory
*.pyc                 # Compiled Python files
*.pyo                 # Optimized compiled Python files

# ========================
# Django
# ========================
db.sqlite3            # Local SQLite database (use PostgreSQL in production)
staticfiles/          # Collected static files (generated by collectstatic)

# ========================
# Virtual Environments
# ========================
.venv/                # Virtual environment (created with python -m venv)
venv/                 # Alternative virtual environment folder name

# ========================
# Package & Build Artifacts
# ========================
*.egg-info/           # Python package metadata
dist/                 # Distribution packages (generated by build tools)
build/                # Build output directory

# ========================
# OS & Editor Files
# ========================
.DS_Store             # macOS folder metadata (not needed in repo)